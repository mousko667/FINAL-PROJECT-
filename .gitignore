# ============================================================
#  OCT Invoice System — .gitignore
# ============================================================

# ── CRITICAL: Never commit secrets ──────────────────────────
.env
.env.local
.env.*.local
*.env
*.p12
*.jks
certs/

# ── Maven ────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
.mvn/timing.properties

# ── Java ─────────────────────────────────────────────────────
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# ── Spring Boot ──────────────────────────────────────────────
HELP.md
spring-shell.log

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
log/
build-errors.txt
compile-errors.txt
compile_errors.txt
test-logs.txt
test-output.txt
test_output.txt

# ── IntelliJ IDEA (kept for compatibility) ───────────────────
.idea/
*.iws
*.iml
*.ipr
out/

# ── VS Code ──────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# ── Antigravity ──────────────────────────────────────────────
.antigravity/cache/
.antigravity/tmp/

# ── Node / React Frontend ────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/*.local

node_modules/
dist/
dist-ssr/
*.local

# ── OS — Windows ─────────────────────────────────────────────
Thumbs.db
Thumbs.db:encdata
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── OS — macOS ───────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Docker ───────────────────────────────────────────────────
docker-compose.override.yml

# ── Test artifacts ───────────────────────────────────────────
/target/surefire-reports/
/target/failsafe-reports/
/target/site/

# ── JaCoCo coverage ──────────────────────────────────────────
/target/site/jacoco/
jacoco.exec

# ── Testcontainers ───────────────────────────────────────────
.testcontainers.properties

# ── MinIO local data (if running locally without Docker) ─────
minio-data/

# ── Upload temp files ────────────────────────────────────────
uploads/
tmp/
temp/
